<Window x:Class="AsyncTasks.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AsyncTasks"
        mc:Ignorable="d" 
        Title="MainWindow" Width="900" Height="700">
    <Grid>
        <Label Content="Программный буфер" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" FontSize="14"/>
        <RichTextBox x:Name="progBuffer" Margin="10,44,550,167" FontSize="14" Height="470" IsReadOnly="True">
            <FlowDocument>
                <Paragraph>
                    <Run Text=""/>
                </Paragraph>
            </FlowDocument>
        </RichTextBox>
        <RichTextBox x:Name="fileBuff" Margin="550,46,10,164" FontSize="14" Height="474" IsReadOnly="True">
            <FlowDocument>
                <Paragraph>
                    <Run Text=""/>
                </Paragraph>
            </FlowDocument>
        </RichTextBox>
        <Button Content="=>" Click="ProgToFile" HorizontalAlignment="Center" Margin="0,113,0,0" VerticalAlignment="Top" FontSize="18" Height="50" Width="150"/>
        <Button Content="&lt;=" Click="FileToProg" HorizontalAlignment="Center" Margin="0,208,0,0" VerticalAlignment="Top" Width="150" Height="50" FontSize="18"/>


        <Button Content="Сгенерировать" Click="BtnGenerate" HorizontalAlignment="Left" Padding="20px 5px" Margin="10,586,0,0" VerticalAlignment="Top" Width="212" FontSize="14"/>
        <Button Click="ClearGeneratedText" HorizontalAlignment="Left" Margin="243,551,0,0" VerticalAlignment="Top" Height="62" Width="107" FontSize="14">
            <TextBlock Text="Очистить программный буфер" TextWrapping="Wrap" TextAlignment="Center"/>
        </Button>
        <Button Content="Загрузить из файла в буфер" Click="LoadFile" Padding="20px 5px" HorizontalAlignment="Left" Margin="550,544,0,0" VerticalAlignment="Top" FontSize="14"/>
        <Button Content="Загрузить из буфера в файл" Click="SaveToFile" Padding="20px 5px" HorizontalAlignment="Left" Margin="550,588,0,0" VerticalAlignment="Top" FontSize="14"/>
        <Button HorizontalAlignment="Left" Click="ClearFileBuffer" Margin="776,544,0,0" VerticalAlignment="Top" Height="76" Width="101">
            <TextBlock Text="Очистить файловый буфер" TextWrapping="Wrap" TextAlignment="Center" FontSize="14"/>
        </Button>
        <Label Content="Файловый буфер" HorizontalAlignment="Left" Margin="550,10,0,0" VerticalAlignment="Top" FontSize="14"/>
        <Label Content="Количество строк" HorizontalAlignment="Left" Margin="10,521,0,0" VerticalAlignment="Top" FontSize="14"/>
        <TextBox x:Name="linesCount" HorizontalAlignment="Left" Margin="14,555,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="208" Height="26" FontSize="14"/>
        <CheckBox Content="Светлая/Темная тема" HorizontalAlignment="Center" Margin="0,281,0,0" VerticalAlignment="Top" FontSize="14"/>

    </Grid>
</Window>
